{
  "hooks": {
    "after:init": "pnpm check"
  },
  "git": {
    "commitMessage": "chore(release): v${version}",
    "tagAnnotation": "v${version}",
    "push": true
  },
  "github": {
    "release": true,
    "releaseName": "v${version}",
    "autoGenerate": true
  },
  "npm": {
    "publish": false
  }
}
